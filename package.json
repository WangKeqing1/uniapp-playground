{
  "name": "uni-preset-vue",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:custom": "uni -c vite.uniapp.config.ts -p",
    "dev:h5": "uni -c vite.uniapp.config.ts",
    "dev:h5:ssr": "uni -c vite.uniapp.config.ts --ssr",
    "dev:mp-alipay": "uni -c vite.uniapp.config.ts -p mp-alipay",
    "dev:mp-baidu": "uni -c vite.uniapp.config.ts -p mp-baidu",
    "dev:mp-jd": "uni -c vite.uniapp.config.ts -p mp-jd",
    "dev:mp-kuaishou": "uni -c vite.uniapp.config.ts -p mp-kuaishou",
    "dev:mp-lark": "uni -c vite.uniapp.config.ts -p mp-lark",
    "dev:mp-qq": "uni -c vite.uniapp.config.ts -p mp-qq",
    "dev:mp-toutiao": "uni -c vite.uniapp.config.ts -p mp-toutiao",
    "dev:mp-harmony": "uni -c vite.uniapp.config.ts -p mp-harmony",
    "dev:mp-weixin": "uni -c vite.uniapp.config.ts -p mp-weixin",
    "dev:mp-xhs": "uni -c vite.uniapp.config.ts -p mp-xhs",
    "dev:electron": "vite -c vite.electron.config.ts",
    "dev:quickapp-webview": "uni -c vite.uniapp.config.ts -p quickapp-webview",
    "dev:quickapp-webview-huawei": "uni -c vite.uniapp.config.ts -p quickapp-webview-huawei",
    "dev:quickapp-webview-union": "uni -c vite.uniapp.config.ts -p quickapp-webview-union",
    "build:custom": "uni build -c vite.uniapp.config.ts -p",
    "build:h5": "uni build -c vite.uniapp.config.ts",
    "build:h5:ssr": "uni build -c vite.uniapp.config.ts --ssr",
    "build:mp-alipay": "uni build -c vite.uniapp.config.ts -p mp-alipay",
    "build:mp-baidu": "uni build -c vite.uniapp.config.ts -p mp-baidu",
    "build:mp-jd": "uni build -c vite.uniapp.config.ts -p mp-jd",
    "build:mp-kuaishou": "uni build -c vite.uniapp.config.ts -p mp-kuaishou",
    "build:mp-lark": "uni build -c vite.uniapp.config.ts -p mp-lark",
    "build:mp-qq": "uni build -c vite.uniapp.config.ts -p mp-qq",
    "build:mp-toutiao": "uni build -c vite.uniapp.config.ts -p mp-toutiao",
    "build:mp-harmony": "uni build -c vite.uniapp.config.ts -p mp-harmony",
    "build:mp-weixin": "uni build -c vite.uniapp.config.ts -p mp-weixin",
    "build:mp-xhs": "uni build -c vite.uniapp.config.ts -p mp-xhs",
    "build:quickapp-webview": "uni build -c vite.uniapp.config.ts -p quickapp-webview",
    "build:quickapp-webview-huawei": "uni build -c vite.uniapp.config.ts -p quickapp-webview-huawei",
    "build:quickapp-webview-union": "uni build -c vite.uniapp.config.ts -p quickapp-webview-union",
    "build:electron": "uni build -c vite.electron.config.ts && vite build -c vite.electron.config.ts && electron-builder",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "build": {
    "appId": "com.uniapp.playground",
    "productName": "Uniapp Playgrond",
    "directories": {
      "output": "dist-publish"
    },
    "files": [
      "dist-electron/**/*",
      "dist",
      "!node_modules/**/*"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-plus": "3.0.0-4080720251210001",
    "@dcloudio/uni-components": "3.0.0-4080720251210001",
    "@dcloudio/uni-h5": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-jd": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-lark": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-qq": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4080720251210001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4080720251210001",
    "@dcloudio/uni-ui": "^1.5.11",
    "vue": "^3.4.21",
    "vue-i18n": "latest"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080720251210001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080720251210001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080720251210001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080720251210001",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "latest",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^4.9.4",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^1.0.24",
    "weapp-tailwindcss": "^4.10.3"
  }
}
