{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "$schema": "https://cdn.jsdelivr.net/gh/uni-helper/uni-app-schemas-vscode/schemas/pages.json",
  "pages": [
    {
      "path": "entry/index",
      "style": {
        "navigationBarTitleText": "uni-app"
      }
    }
  ],
  "subPackages": [
    {
      "root": "views/test",
      "pages": [
        {
          "path": "test",
          "style": {
            "navigationBarTitleText": "分包测试页"
          }
        }
      ]
    },
    {
      "root": "views/about",
      "pages": [
        {
          "path": "about",
          "style": {
            "navigationBarTitleText": "关于我们测试页"
          }
        }
      ]
    },
    {
      "root": "views/camera",
      "pages": [
        {
          "path": "camera",
          "style": {
            "navigationBarTitleText": "相机测试"
          }
        }
      ]
    },
    {
      "root": "views/stability",
      "pages": [
        {
          "path": "stability",
          "style": {
            "navigationBarTitleText": "安全性与稳定性测试"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  }
}
